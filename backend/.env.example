APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# MySQL / MariaDB (local dev; palitan ang port kung ibang serbisyo)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3307
DB_DATABASE=laravel1
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Mail (Gmail SMTP) ---
# IMPORTANT:
# - Use an **App Password**, not your normal Gmail password.
# - Google Account → Security → enable 2-Step Verification → App passwords → generate for "Mail".
#
# Local dev note:
# - If MAIL_MAILER=log, emails are NOT sent; they appear in storage/logs/laravel.log only.
# - To actually send student credentials + OTP emails, set MAIL_MAILER=smtp (below).
#
MAIL_MAILER=smtp
# For Gmail:
# - Port 587 (STARTTLS): use scheme "smtp"
# - Port 465 (implicit TLS): use scheme "smtps"
MAIL_SCHEME=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=kianmrnd01@gmail.com
MAIL_PASSWORD=uamzjjbcgqymbemm
MAIL_FROM_ADDRESS="kianmrnd01@gmail.com"
MAIL_FROM_NAME="College of Computing Studies"
MAIL_EHLO_DOMAIN=localhost

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Default dean account (DeanUserSeeder); override per environment
DEFAULT_DEAN_EMAIL=mirandakianandrei25@gmail.com
DEFAULT_DEAN_PASSWORD=password
